# 应用配置
APP_NAME=AI应用通用框架
APP_VERSION=1.0.0
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/ai_framework

# Redis配置
REDIS_URL=redis://localhost:6379

# MongoDB配置
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=ai_framework

# Milvus向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 模型配置
MODEL_CACHE_DIR=./models
DEFAULT_LLM_MODEL=gpt-3.5-turbo
DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# API配置
API_V1_PREFIX=/api/v1

# 安全配置
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 监控配置
PROMETHEUS_ENABLED=true

# LLM提供商配置
# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MiMo (Xiaomi)
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://api.mimo.xiaomi.com
MIMO_MODEL=mimo-auto

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-3.5-turbo

# 通义千问
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_MODEL=qwen-turbo

# 智谱GLM
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn
GLM_MODEL=glm-4-flash

# 默认提供商 (deepseek/mimo/openai/qwen/glm)
DEFAULT_PROVIDER=deepseek

# 降级顺序 (主提供商失败时自动切换)
FALLBACK_ORDER=["deepseek", "mimo", "qwen", "glm", "openai"]
